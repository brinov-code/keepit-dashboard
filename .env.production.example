# ============================================================================
# CONFIGURAÇÃO DE PRODUÇÃO - Dashboard Keepit Elite Partner
# ============================================================================
# Copie este arquivo para .env.production e preencha com seus valores

# ============================================================================
# BANCO DE DADOS
# ============================================================================
# MySQL/TiDB connection string
# Formato: mysql://usuario:senha@host:porta/banco_dados
DATABASE_URL=mysql://seu_usuario:sua_senha@seu_host:3306/keepit_dashboard

# ============================================================================
# AUTENTICAÇÃO
# ============================================================================
# Chave secreta para assinar cookies de sessão
# Gere com: openssl rand -base64 32
JWT_SECRET=sua_chave_secreta_aqui

# ============================================================================
# OAUTH MANUS
# ============================================================================
# ID da aplicação Manus
VITE_APP_ID=seu_app_id_aqui

# URL do servidor OAuth Manus
OAUTH_SERVER_URL=https://api.manus.im

# URL do portal OAuth Manus (frontend)
VITE_OAUTH_PORTAL_URL=https://manus.im

# ============================================================================
# AMBIENTE
# ============================================================================
NODE_ENV=production

# ============================================================================
# OPCIONAL: APIs EXTERNAS
# ============================================================================
# Se usar integração com LLM, storage, etc
# BUILT_IN_FORGE_API_URL=sua_url
# BUILT_IN_FORGE_API_KEY=sua_chave

# ============================================================================
# INFORMAÇÕES DO PROPRIETÁRIO
# ============================================================================
# OpenID do proprietário (para promover a admin)
OWNER_OPEN_ID=seu_open_id

# Nome do proprietário
OWNER_NAME=Seu Nome
